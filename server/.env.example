# Database (Railway provides this automatically)
DATABASE_URL="mysql://user:password@host:port/dispatch"

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_64_byte_hex_string"
JWT_REFRESH_SECRET="replace_with_different_64_byte_hex_string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Cloudinary (free tier at cloudinary.com)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Email OTP — use a Gmail app password
# Enable 2FA on Gmail → App passwords → generate one
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_gmail@gmail.com"
SMTP_PASS="your_gmail_app_password"
SMTP_FROM="Dispatch <your_gmail@gmail.com>"

# Pricing config (in local currency - Lesotho Loti)
BASE_FARE=15
RATE_PER_KM=8
RATE_PER_MIN=1.5
DRIVER_CUT_PERCENT=80
